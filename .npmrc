@brainwav:registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
ignore-scripts=true
# @brainwav/* packages are vendored in vendor/brainwav/ (not on public registry).
# NPM_TOKEN is sourced from 1Password via ~/.zshenv
# (op://brAInwav Development/NPM_TOKEN/credential) with ~/.codex/.env as fallback.
